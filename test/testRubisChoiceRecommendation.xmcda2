<alternativesComparisons name="Stilde" mcdaConcept="outrankingDigraph">
<description>
<title>Bipolar-valued Outranking Relation</title>
<comment>Rubis Choice Recommendation Relation</comment>
</description>
<valuation>
<description>
<subTitle>Valuation Domain</subTitle>
<comment>Significance degrees</comment>
</description>
<valuationType>bipolar</valuationType>
<quantitative><minimum><real>-1.00</real></minimum><maximum><real>1.00</real></maximum></quantitative>
</valuation>
<pairs>
<description>
<subTitle>Valued Adjacency Table</subTitle>
<comment>Pairwise outranking significance degrees in the range: -1.00 to 1.00</comment>
