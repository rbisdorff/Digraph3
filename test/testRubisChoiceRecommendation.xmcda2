<comment>No comment</comment>
<version>Rubis</version>
</description>
<active>true</active>
<weight><value><real>4.00</real></value></weight>
<objectiveCriteria>['ec1', 'ec4', 'ec5', 'ec7']</objectiveCriteria>
</objective>
<objective id="Env" name="Environmental aspect" mcdaConcept="objective">
