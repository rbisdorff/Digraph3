<projectReference id="testRubisChoiceRecommendation" name="rel_random3ObjectivesPerfTab">
<title>Rubis Best Choice Recommendation</title>
<author>digraphs Module (RB)</author>
<version>saved from Python</version>
</projectReference>
<methodParameters id="Rubis" name="Rubis best choice method">
<description>
<subTitle>Method data</subTitle>
<comment>Rubis best choice recommendation in XMCDA format.</comment>
<version>1.0</version>
</description>
<parameters>
<parameter name="variant">
<value>
<label>standard</label>
</value>
</parameter>
<parameter name="valuationType">
<value>
<label>bipolar</label>
</value>
</parameter>
<parameter name="vetoType">
<value>
<label>normal</label>
</value>
</parameter>
</parameters>
</methodParameters>
<alternatives mcdaConcept="alternatives">
<description>
<title>List of Alternatives</title>
<subTitle>Potential decision actions.</subTitle>
</description>
<alternative id="p1" name="action p1 Eco+ Soc+ Env-">
<description>
<comment>random public polivy</comment>
</description>
<type>real</type>
<active>true</active>
</alternative>
<alternative id="p2" name="action p2 Eco- Soc+ Env+">
<description>
<comment>random public polivy</comment>
</description>
<type>real</type>
<active>true</active>
</alternative>
<alternative id="p3" name="action p3 Eco- Soc~ Env+">
<description>
<comment>random public polivy</comment>
</description>
<type>real</type>
<active>true</active>
</alternative>
<alternative id="p4" name="action p4 Eco- Soc+ Env~">
<description>
<comment>random public polivy</comment>
</description>
<type>real</type>
<active>true</active>
</alternative>
<alternative id="p5" name="action p5 Eco- Soc+ Env+">
<description>
<comment>random public polivy</comment>
</description>
<type>real</type>
<active>true</active>
</alternative>
</alternatives>
<alternatives mcdaConcept="cocaActions">
<description>
<subTitle>Coca digraph actions</subTitle>
<comment>Chordless odd circuits added to the original outranking digraph.</comment>
</description>
<alternative id="_p1_p2_p3_" name="_p1_p2_p3_">
<description>
<comment>chordless odd 3-circuit</comment>
</description>
<type>fictive</type>
</alternative>
</alternatives>
<objectives mcdaConcept="objectives">
<description>
<subTitle>Set of decision objectives</subTitle>
</description>
<objective id="Eco" name="Economical aspect" mcdaConcept="objective">
<description>
<comment>No comment</comment>
<version>Rubis</version>
</description>
<active>true</active>
<weight><value><real>2.00</real></value></weight>
<objectiveCriteria>['ec1', 'ec5']</objectiveCriteria>
</objective>
<objective id="Env" name="Environmental aspect" mcdaConcept="objective">
<description>
<comment>No comment</comment>
<version>Rubis</version>
</description>
<active>true</active>
<weight><value><real>2.00</real></value></weight>
<objectiveCriteria>['en3', 'en6']</objectiveCriteria>
</objective>
<objective id="Soc" name="Societal aspect" mcdaConcept="objective">
<description>
<comment>No comment</comment>
<version>Rubis</version>
</description>
<active>true</active>
<weight><value><real>3.00</real></value></weight>
<objectiveCriteria>['so2', 'so4', 'so7']</objectiveCriteria>
</objective>
</objectives>
