<value>
<label>standard</label>
</value>
</parameter>
<parameter name="valuationType">
<value>
<label>bipolar</label>
</value>
</parameter>
<parameter name="vetoType">
<value>
<label>normal</label>
</value>
</parameter>
</parameters>
</methodParameters>
