</description>
<type>real</type>
<active>true</active>
</alternative>
<alternative id="p5" name="action p5 Eco- Soc+ Env-">
<description>
<comment>random public polivy</comment>
</description>
<type>real</type>
<active>true</active>
</alternative>
</alternatives>
<objectives mcdaConcept="objectives">
<description>
<subTitle>Set of decision objectives</subTitle>
</description>
<objective id="Eco" name="Economical aspect" mcdaConcept="objective">
<description>
<comment>No comment</comment>
<version>Rubis</version>
</description>
<active>true</active>
<weight><value><real>1.00</real></value></weight>
<objectiveCriteria>['ec1']</objectiveCriteria>
</objective>
<objective id="Env" name="Environmental aspect" mcdaConcept="objective">
<description>
<comment>No comment</comment>
<version>Rubis</version>
</description>
<active>true</active>
<weight><value><real>3.00</real></value></weight>
<objectiveCriteria>['en3', 'en6', 'en7']</objectiveCriteria>
</objective>
<objective id="Soc" name="Societal aspect" mcdaConcept="objective">
<description>
<comment>No comment</comment>
<version>Rubis</version>
</description>
<active>true</active>
<weight><value><real>3.00</real></value></weight>
<objectiveCriteria>['so2', 'so4', 'so5']</objectiveCriteria>
</objective>
