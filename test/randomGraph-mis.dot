n12 [shape = "circle", label = "v12", style = "filled", color = coral];
n13 [shape = "circle", label = "v13", style = "filled", color = coral];
n14 [shape = "circle", label = "v14"];
n15 [shape = "circle", label = "v15"];
n16 [shape = "circle", label = "v16", style = "filled", color = coral];
n17 [shape = "circle", label = "v17", style = "filled", color = coral];
n18 [shape = "circle", label = "v18", style = "filled", color = coral];
n19 [shape = "circle", label = "v19"];
n20 [shape = "circle", label = "v20", style = "filled", color = coral];
n1-- n13 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n2-- n9 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n2-- n16 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
