n4-- n8 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n6-- n18 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n8-- n12 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n9-- n17 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n10-- n14 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
