n17 [shape = "circle", label = "v17", style = "filled", color = coral];
n18 [shape = "circle", label = "v18", style = "filled", color = coral];
n19 [shape = "circle", label = "v19", style = "filled", color = coral];
n20 [shape = "circle", label = "v20", style = "filled", color = coral];
n1-- n13 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
