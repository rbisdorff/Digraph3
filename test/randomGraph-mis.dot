n9 [shape = "circle", label = "v09", style = "filled", color = coral];
n10 [shape = "circle", label = "v10"];
n11 [shape = "circle", label = "v11", style = "filled", color = coral];
n12 [shape = "circle", label = "v12", style = "filled", color = coral];
n13 [shape = "circle", label = "v13", style = "filled", color = coral];
n14 [shape = "circle", label = "v14"];
n15 [shape = "circle", label = "v15", style = "filled", color = coral];
n16 [shape = "circle", label = "v16"];
n17 [shape = "circle", label = "v17"];
n18 [shape = "circle", label = "v18", style = "filled", color = coral];
n19 [shape = "circle", label = "v19", style = "filled", color = coral];
n20 [shape = "circle", label = "v20"];
n1-- n6 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n3-- n11 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n4-- n10 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
