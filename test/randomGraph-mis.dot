strict graph G {
graph [ bgcolor = cornsilk, fontname = "Helvetica-Oblique",
 fontsize = 12,
 label = "\nDigraph3 (graphviz), R. Bisdorff, 2019", size="7,7"];
n1 [shape = "circle", label = "v01"];
n2 [shape = "circle", label = "v02"];
n3 [shape = "circle", label = "v03"];
n4 [shape = "circle", label = "v04", style = "filled", color = coral];
n5 [shape = "circle", label = "v05", style = "filled", color = coral];
n6 [shape = "circle", label = "v06", style = "filled", color = coral];
n7 [shape = "circle", label = "v07", style = "filled", color = coral];
n8 [shape = "circle", label = "v08"];
n9 [shape = "circle", label = "v09", style = "filled", color = coral];
n10 [shape = "circle", label = "v10", style = "filled", color = coral];
n11 [shape = "circle", label = "v11", style = "filled", color = coral];
n12 [shape = "circle", label = "v12", style = "filled", color = coral];
n13 [shape = "circle", label = "v13"];
n14 [shape = "circle", label = "v14"];
n15 [shape = "circle", label = "v15"];
n16 [shape = "circle", label = "v16", style = "filled", color = coral];
n17 [shape = "circle", label = "v17"];
n18 [shape = "circle", label = "v18"];
n19 [shape = "circle", label = "v19", style = "filled", color = coral];
n20 [shape = "circle", label = "v20"];
n1-- n6 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n1-- n11 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n1-- n17 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
