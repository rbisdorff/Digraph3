n8-- n14 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n10-- n14 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
n10-- n15 [dir=both,style="setlinewidth(1)",color=black, arrowhead=none, arrowtail=none] ;
