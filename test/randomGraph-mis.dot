strict graph G {
graph [ bgcolor = cornsilk, fontname = "Helvetica-Oblique",
 fontsize = 12,
 label = "\nDigraph3 (graphviz), R. Bisdorff, 2019", size="7,7"];
n1 [shape = "circle", label = "v01", style = "filled", color = coral];
n2 [shape = "circle", label = "v02", style = "filled", color = coral];
n3 [shape = "circle", label = "v03"];
