digraph G {
graph [ bgcolor = cornsilk, fontname = "Helvetica-Oblique",
 fontsize = 12,
 label = "\nDigraph3 (graphviz), R. Bisdorff, 2020", size="7,7"];
n1 [shape = "circle", label = "a1c", style = "filled", color = lightblue];
n2 [shape = "circle", label = "a2c"];
n3 [shape = "circle", label = "a3a"];
n4 [shape = "circle", label = "a4c"];
n5 [shape = "circle", label = "a5n"];
n6 [shape = "circle", label = "a6a"];
n7 [shape = "circle", label = "a7c", style = "filled", color = gold];
n1-> n2 [dir=back, color=black] ;
n1-> n3 [dir=back, color=black] ;
n1-> n4 [dir=both,style="setlinewidth(2)",color=black, arrowhead=normal, arrowtail=normal] ;
n1-> n5 [dir=back, color=black] ;
n1-> n6 [dir=back, color=black] ;
n1-> n7 [dir=back, color=black] ;
n2-> n3 [dir=forward, color=black] ;
n2-> n4 [dir=forward, color=black] ;
n2-> n5 [dir=forward, color=black] ;
n2-> n6 [dir=forward, color=black] ;
n2-> n7 [dir=both,style="setlinewidth(2)",color=black, arrowhead=normal, arrowtail=normal] ;
n3-> n4 [dir=both, color=grey, arrowhead=empty, arrowtail=empty] ;
n3-> n5 [dir=both,style="setlinewidth(2)",color=black, arrowhead=normal, arrowtail=normal] ;
n3-> n6 [dir=both,style="setlinewidth(2)",color=black, arrowhead=normal, arrowtail=normal] ;
n3-> n7 [dir=back, color=black] ;
n4-> n5 [dir=forward, color=black] ;
n4-> n6 [dir=both, color=grey, arrowhead=empty, arrowtail=empty] ;
n4-> n7 [dir=back, color=black] ;
n5-> n6 [dir=both, color=black, arrowtail=normal, arrowhead=empty] ;
n5-> n7 [dir=back, color=black] ;
n6-> n7 [dir=back, color=black] ;
{rank=max; n7 }
{rank=min; n1 }
}
