digraph G {
graph [ bgcolor = cornsilk, fontname = "Helvetica-Oblique",
 fontsize = 12,
 label = "\nDigraph3 (graphviz), R. Bisdorff, 2020", size="7,7"];
n1 [shape = "circle", label = "a1a"];
n2 [shape = "circle", label = "a2a"];
n3 [shape = "circle", label = "a3n", style = "filled", color = lightblue];
n4 [shape = "circle", label = "a4n"];
n5 [shape = "circle", label = "a5n"];
n6 [shape = "circle", label = "a6n", style = "filled", color = gold];
n7 [shape = "circle", label = "a7a"];
n1-> n2 [dir=back, color=black] ;
n1-> n3 [dir=both,style="setlinewidth(2)",color=black, arrowhead=normal, arrowtail=normal] ;
n1-> n4 [dir=back, color=black] ;
n1-> n5 [dir=back, color=black] ;
n1-> n6 [dir=back, color=black] ;
n1-> n7 [dir=back, color=black] ;
n2-> n3 [dir=forward, color=black] ;
n2-> n4 [dir=forward, color=black] ;
n2-> n5 [dir=both,style="setlinewidth(2)",color=black, arrowhead=normal, arrowtail=normal] ;
n2-> n6 [dir=back, color=black] ;
n2-> n7 [dir=back, color=black] ;
n3-> n4 [dir=back, color=black] ;
n3-> n5 [dir=back, color=black] ;
n3-> n6 [dir=back, color=black] ;
n3-> n7 [dir=back, color=black] ;
n4-> n5 [dir=back, color=black] ;
n4-> n6 [dir=back, color=black] ;
n4-> n7 [dir=back, color=black] ;
n5-> n6 [dir=back, color=black] ;
n5-> n7 [dir=both, color=black, arrowhead=normal, arrowtail=empty] ;
n6-> n7 [dir=both, color=black, arrowhead=normal, arrowtail=empty] ;
{rank=max; n6 }
{rank=min; n3 }
}
