strict graph G {
graph [ bgcolor = cornsilk, fontname = "Helvetica-Oblique",
 fontsize = 12,
 label = "\nDigraph3 (graphviz), R. Bisdorff, 2019", size="7,7"];
n1 [shape = "circle", label = "v01"];
n2 [shape = "circle", label = "v02"];
n3 [shape = "circle", label = "v03"];
n4 [shape = "circle", label = "v04"];
n5 [shape = "circle", label = "v05"];
n6 [shape = "circle", label = "v06"];
n7 [shape = "circle", label = "v07"];
n8 [shape = "circle", label = "v08"];
n9 [shape = "circle", label = "v09"];
n10 [shape = "circle", label = "v10"];
n1-- n4 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n1-- n5 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n1-- n6 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n1-- n8 [dir=both,style="setlinewidth(3)",color=red, arrowhead=none, arrowtail=none] ;
n1-- n9 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n2-- n5 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n2-- n6 [dir=both,style="setlinewidth(3)",color=red, arrowhead=none, arrowtail=none] ;
n2-- n9 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n3-- n7 [dir=both,style="setlinewidth(3)",color=red, arrowhead=none, arrowtail=none] ;
n3-- n8 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n3-- n10 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n4-- n5 [dir=both,style="setlinewidth(3)",color=red, arrowhead=none, arrowtail=none] ;
n4-- n6 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n4-- n7 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n4-- n9 [dir=both,style="setlinewidth(3)",color=red, arrowhead=none, arrowtail=none] ;
n5-- n8 [dir=both,style="setlinewidth(3)",color=red, arrowhead=none, arrowtail=none] ;
n5-- n9 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n6-- n7 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n6-- n8 [dir=both,style="setlinewidth(3)",color=red, arrowhead=none, arrowtail=none] ;
n7-- n8 [dir=both,style="setlinewidth(3)",color=red, arrowhead=none, arrowtail=none] ;
n7-- n9 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n8-- n9 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
n8-- n10 [dir=both,style="setlinewidth(3)",color=red, arrowhead=none, arrowtail=none] ;
n9-- n10 [dir=both, color=grey, arrowhead=none, arrowtail=none] ;
}
