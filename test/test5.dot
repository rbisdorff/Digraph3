digraph G {
graph [ bgcolor = cornsilk, ordering = out, fontname = "Helvetica-Oblique",
 fontsize = 12,
 label = "\nDigraph3 (graphviz)\n R. Bisdorff, 2020", size="7,7",fontsize=10];
a1 [shape = "circle", label = "a1a", fontsize=10];
a2 [shape = "circle", label = "a2n", fontsize=10];
a3 [shape = "circle", label = "a3a", fontsize=10];
a4 [shape = "circle", label = "a4c", fontsize=10];
a5 [shape = "circle", label = "a5c", fontsize=10];
a6 [shape = "circle", label = "a6n", fontsize=10];
a7 [shape = "circle", label = "a7a", fontsize=10];
a8 [shape = "circle", label = "a8a", fontsize=10];
{ rank = 0; a7; }
{ rank = 1; a5; }
{ rank = 2; a8; }
{ rank = 3; a6; }
{ rank = 4; a2; a4; }
{ rank = 5; a3; }
{ rank = 6; a1; }
a7-> a5 [style="setlinewidth(1)",color=black] ;
a5-> a8 [style="setlinewidth(1)",color=black] ;
a8-> a6 [style="setlinewidth(1)",color=black] ;
a6-> a2 [style="setlinewidth(1)",color=black] ;
a6-> a4 [style="setlinewidth(1)",color=black] ;
a2-> a3 [style="setlinewidth(1)",color=black] ;
a4-> a3 [style="setlinewidth(1)",color=black] ;
a3-> a1 [style="setlinewidth(1)",color=black] ;
}
 
