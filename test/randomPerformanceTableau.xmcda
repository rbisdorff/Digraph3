<criterion id="b1" >
<description>
<name>random cardinal benefit criterion</name>
<type>criterion</type>
<comment>Evaluation generator: truncated normal law with variable mean (mu) and standard deviation (stdev = 20%). Cheap actions: mu = 30%; neutral actions: mu = 50%; advantageous actions: mu = 70%.</comment>
<version>performance</version>
</description>
<status>active</status>
<significance><real>2.00</real></significance>
