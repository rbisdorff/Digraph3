digraph G {
graph [ bgcolor = cornsilk, fontname = "Helvetica-Oblique",
 fontsize = 12,
 label = "\nDigraph3 (graphviz), R. Bisdorff, 2020", size="7,7"];
n1 [shape = "circle", label = "p1"];
n2 [shape = "circle", label = "p2"];
n3 [shape = "circle", label = "p3"];
n4 [shape = "circle", label = "p4"];
n5 [shape = "circle", label = "p5"];
n6 [shape = "circle", label = "p6"];
n7 [shape = "circle", label = "p7"];
n1-> n2 [dir=both, color=black, arrowhead=normal, arrowtail=empty] ;
n1-> n3 [dir=both, color=grey, arrowhead=empty, arrowtail=empty] ;
n1-> n4 [dir=forward, color=black] ;
n1-> n5 [dir=both, color=black, arrowtail=normal, arrowhead=empty] ;
n1-> n6 [dir=both, color=grey, arrowhead=empty, arrowtail=empty] ;
n1-> n7 [dir=back, color=black] ;
n2-> n3 [dir=back, color=black] ;
n2-> n4 [dir=both,style="setlinewidth(2)",color=black, arrowhead=normal, arrowtail=normal] ;
n2-> n5 [dir=back, color=black] ;
n2-> n6 [dir=back, color=black] ;
n2-> n7 [dir=back, color=black] ;
n3-> n4 [dir=forward, color=black] ;
n3-> n5 [dir=back, color=black] ;
n3-> n6 [dir=both,style="setlinewidth(2)",color=black, arrowhead=normal, arrowtail=normal] ;
n3-> n7 [dir=both, color=black, arrowtail=normal, arrowhead=empty] ;
n4-> n5 [dir=back, color=black] ;
n4-> n6 [dir=back, color=black] ;
n4-> n7 [dir=back, color=black] ;
n5-> n6 [dir=both, color=grey, arrowhead=empty, arrowtail=empty] ;
n5-> n7 [dir=both, color=grey, arrowhead=empty, arrowtail=empty] ;
n6-> n7 [dir=both, color=grey, arrowhead=empty, arrowtail=empty] ;
}
